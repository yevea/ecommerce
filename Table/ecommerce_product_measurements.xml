<?xml version="1.0" encoding="UTF-8"?>
<table>
    <column>
        <name>id</name>
        <type>serial</type>
        <null>NO</null>
    </column>
    <column>
        <name>product_referencia</name>
        <type>character varying(30)</type>
        <null>NO</null>
    </column>
    <column>
        <name>measurement_enabled</name>
        <type>boolean</type>
        <default>false</default>
    </column>
    <column>
        <name>measurement_type</name>
        <type>character varying(20)</type>
        <default>'area'</default>
    </column>
    <column>
        <name>pricing_mode</name>
        <type>character varying(20)</type>
        <default>'per_measurement'</default>
    </column>
    <column>
        <name>unit_value</name>
        <type>double precision</type>
        <default>1</default>
    </column>
    <column>
        <name>measurement_unit</name>
        <type>character varying(20)</type>
        <default>'m2'</default>
    </column>
    <column>
        <name>min_value</name>
        <type>double precision</type>
        <default>0</default>
    </column>
    <column>
        <name>max_value</name>
        <type>double precision</type>
        <default>0</default>
    </column>
    <column>
        <name>step_value</name>
        <type>double precision</type>
        <default>0.01</default>
    </column>
    <column>
        <name>custom_label</name>
        <type>character varying(100)</type>
        <null>YES</null>
    </column>
    <constraint>
        <name>pk_ecommerce_product_measurements</name>
        <type>PRIMARY KEY (id)</type>
    </constraint>
    <constraint>
        <name>uq_ecommerce_product_measurements_ref</name>
        <type>UNIQUE (product_referencia)</type>
    </constraint>
    <constraint>
        <name>fk_ecommerce_product_measurements_product</name>
        <type>FOREIGN KEY (product_referencia) REFERENCES productos (referencia) ON DELETE CASCADE ON UPDATE CASCADE</type>
    </constraint>
</table>
