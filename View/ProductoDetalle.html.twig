{% extends "Master/MenuTemplate.html.twig" %}

{% block navbar %}{% endblock %}

{% block body %}
<div class="container mt-4">

    {% if fsc.product is not null %}
    {# Schema.org structured data for AI agents and search engines #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Product",
        "name": "{% if fsc.defaultVariant and fsc.defaultVariant.description is not empty %}{{ fsc.product.name | e('js') }} – {{ fsc.defaultVariant.description | e('js') }}{% else %}{{ fsc.product.name | e('js') }}{% endif %}",
        "description": "{{ fsc.product.description | e('js') }}",
        "sku": "{{ fsc.product.referencia }}",
        "material": "{{ trans('olive-wood') }}",
        "url": "{{ asset('ProductoDetalle') }}?url={{ fsc.product.slug }}",
        {% if fsc.productImages is not empty %}"image": "{{ fsc.productImages[0].url }}",{% endif %}
        "brand": {
            "@type": "Brand",
            "name": "{{ trans('sawmill') }}"
        },
        "manufacturer": {
            "@type": "Organization",
            "name": "{{ trans('sawmill') }}",
            "description": "{{ trans('sawmill-desc') }}"
        },
        "category": "{% if fsc.familyType == 'tableros' %}{{ trans('olive-wood-boards') }}{% elseif fsc.familyType == 'tablones' %}{{ trans('wood-planks') }}{% elseif fsc.familyType == 'artesania' %}{{ trans('olive-wood-crafts') }}{% else %}{{ trans('olive-wood') }}{% endif %}",
        "offers": {
            "@type": "Offer",
            "price": "{{ fsc.defaultVariant ? fsc.defaultVariant.price : fsc.product.price }}",
            "priceCurrency": "EUR",
            {% if fsc.familyType == 'tableros' %}"unitCode": "MTK",
            "unitText": "m²",{% endif %}
            "availability": "{% if fsc.familyType == 'artesania' and fsc.product.isSold %}https://schema.org/SoldOut{% elseif fsc.product.nostock %}https://schema.org/InStock{% elseif (fsc.defaultVariant ? fsc.defaultVariant.stock : fsc.product.stock) > 0 %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
            "areaServed": [
                {"@type": "Country", "name": "Spain"},
                {"@type": "Country", "name": "France"},
                {"@type": "Country", "name": "Germany"},
                {"@type": "Place", "name": "European Union"}
            ],
            "shippingDetails": {
                "@type": "OfferShippingDetails",
                "shippingDestination": {
                    "@type": "DefinedRegion",
                    "name": "European Union"
                }
            }
        }
        {% if fsc.productVariants is not empty %},
        "hasVariant": [
            {% for variant in fsc.productVariants %}
            {
                "@type": "ProductModel",
                "name": "{{ variant.description | e('js') }}",
                "sku": "{{ variant.referencia }}",
                "offers": {
                    "@type": "Offer",
                    "price": "{{ variant.price }}",
                    "priceCurrency": "EUR"
                }
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ]
        {% endif %}
    }
    </script>

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
            <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <a href="{{ asset('Tableros') }}" itemprop="item"><span itemprop="name">{{ trans('tableros') }}</span></a>
                <meta itemprop="position" content="1">
            </li>
            <li class="breadcrumb-item active" aria-current="page" id="breadcrumb-product-name" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <span itemprop="name">
                {% if fsc.defaultVariant and fsc.defaultVariant.description is not empty %}
                    {{ fsc.product.name }} – {{ fsc.defaultVariant.description }}
                {% else %}
                    {{ fsc.product.name }}
                {% endif %}
                </span>
                <meta itemprop="position" content="2">
            </li>
        </ol>
    </nav>

    <div class="row">
        {# Images column #}
        <div class="col-md-5 mb-4">
            {% if fsc.productImages is not empty %}
            <div id="productCarousel" class="carousel slide mb-3" data-bs-ride="carousel">
                <div class="carousel-inner" id="carousel-inner">
                    {% for img in fsc.productImages %}
                    <div class="carousel-item {% if loop.first %}active{% endif %}" data-idvariante="{{ img.idvariante ?? '' }}">
                        <img src="{{ img.url }}" class="d-block w-100 rounded" alt="{{ img.alt }}" style="max-height: 400px; object-fit: contain; background:#f8f9fa;">
                    </div>
                    {% endfor %}
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev" id="carousel-prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next" id="carousel-next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
            {% else %}
            <div class="bg-light d-flex align-items-center justify-content-center rounded mb-3" id="no-image-placeholder" style="height: 300px;">
                <i class="fa-solid fa-image fa-5x text-muted"></i>
            </div>
            {% endif %}
        </div>

        {# Product info column #}
        <div class="col-md-7 mb-4">
            <h1 class="h2 mb-2" id="product-title">
                {% if fsc.defaultVariant and fsc.defaultVariant.description is not empty %}
                    {{ fsc.product.name }} – {{ fsc.defaultVariant.description }}
                {% else %}
                    {{ fsc.product.name }}
                {% endif %}
            </h1>

            {% set currentPrice = fsc.defaultVariant ? fsc.defaultVariant.price : fsc.product.price %}
            {% set currentStock = fsc.defaultVariant ? fsc.defaultVariant.stock : fsc.product.stock %}
            <div class="d-flex align-items-center gap-3 mb-3">
                <span id="variant-price" class="mb-0">
                    {{ fsc.formatMoney(currentPrice) }}
                    {% if fsc.familyType == 'tableros' %}
                    <small class="text-muted">/m²</small>
                    {% endif %}
                </span>
                {% if fsc.familyType == 'artesania' and fsc.product.isSold %}
                <span id="variant-stock-badge" class="badge bg-warning text-dark fs-6">{{ trans('sold') }}</span>
                {% elseif fsc.product.nostock %}
                <span id="variant-stock-badge"></span>
                {% elseif currentStock > 0 %}
                <span id="variant-stock-badge" class="badge bg-success fs-6">{{ trans('in-stock') }}</span>
                {% else %}
                <span id="variant-stock-badge" class="badge bg-danger fs-6">{{ trans('out-of-stock') }}</span>
                {% endif %}
            </div>

            {% if fsc.product.description is not empty %}
            <div class="mb-4">
                <h5>{{ trans('description') }}</h5>
                <p class="text-muted">{{ fsc.product.description | nl2br }}</p>
            </div>
            {% endif %}

            {# Tablones: Show variant dimensions (non-editable) #}
            {% if fsc.familyType == 'tablones' %}
            <div class="mb-3" id="tablones-dimensions">
                <h6>{{ trans('dimensions') }}</h6>
                {% set dimVariant = fsc.defaultVariant %}
                {% if dimVariant %}
                <table class="table table-sm table-bordered" style="max-width: 300px;" id="dimensions-table">
                    {% if dimVariant.largo is not null %}
                    <tr><td class="fw-semibold">{{ trans('largo') }}</td><td id="dim-largo">{{ dimVariant.largo }}</td></tr>
                    {% endif %}
                    {% if dimVariant.ancho is not null %}
                    <tr><td class="fw-semibold">{{ trans('ancho') }}</td><td id="dim-ancho">{{ dimVariant.ancho }}</td></tr>
                    {% endif %}
                    {% if dimVariant.espesor is not null %}
                    <tr><td class="fw-semibold">{{ trans('espesor') }}</td><td id="dim-espesor">{{ dimVariant.espesor }}</td></tr>
                    {% endif %}
                </table>
                {% endif %}
            </div>
            {% endif %}

            {# Attribute-based variant selectors #}
            {% if fsc.productAttributes is not empty %}
            <div class="mb-4" id="attribute-selectors">
                {% for codatributo, attr in fsc.productAttributes %}
                <div class="mb-2">
                    <label class="form-label fw-semibold">{{ attr.nombre }}</label>
                    <select class="form-select attr-selector" data-codatributo="{{ codatributo }}" onchange="updateVariantFromAttributes()">
                        {% for idVal, valor in attr.values %}
                        <option value="{{ idVal }}"
                            {% if fsc.defaultVariant and fsc.defaultVariant.attributes[codatributo] == idVal %}selected{% endif %}>
                            {{ valor }}
                        </option>
                        {% endfor %}
                    </select>
                </div>
                {% endfor %}
            </div>
            {% elseif fsc.productVariants is not empty %}
            {# Fallback: simple dropdown when variants have no attribute data #}
            <div class="mb-4">
                <h5>{{ trans('variants') }}</h5>
                <select id="variant-selector" class="form-select" onchange="updateVariant(this)">
                    {% for variant in fsc.productVariants %}
                    <option value="{{ variant.referencia }}" data-price="{{ variant.price }}" data-stock="{{ variant.stock }}"
                        data-idvariante="{{ variant.idvariante ?? '' }}"
                        data-description="{{ variant.description }}"
                        data-largo="{{ variant.largo ?? '' }}"
                        data-ancho="{{ variant.ancho ?? '' }}"
                        data-espesor="{{ variant.espesor ?? '' }}"
                        {% if fsc.defaultVariant and fsc.defaultVariant.referencia == variant.referencia %}selected{% endif %}>
                        {{ variant.description }} – {{ fsc.formatMoney(variant.price) }}
                    </option>
                    {% endfor %}
                </select>
            </div>
            {% endif %}

            {# === ARTESANÍA: sold overlay === #}
            {% if fsc.familyType == 'artesania' and fsc.product.isSold %}
            <div class="alert alert-warning">
                <i class="fa-solid fa-tag"></i> {{ trans('sold') }}
            </div>

            {# === TABLEROS: custom dimension input === #}
            {% elseif fsc.familyType == 'tableros' %}
            {% set showForm = fsc.product.nostock or fsc.product.stock > 0 %}
            {% if showForm %}
            <form method="post" action="{{ asset('ProductoDetalle') }}?url={{ fsc.product.slug }}" id="tableros-form">
                <input type="hidden" name="action" value="add-to-cart">
                <input type="hidden" name="product_referencia" id="add-referencia"
                    value="{{ fsc.defaultVariant ? fsc.defaultVariant.referencia : fsc.product.referencia }}">
                <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">

                <h5>{{ trans('enter-dimensions') }}</h5>
                {% if fsc.familyData %}
                <p class="text-muted small">
                    {% if fsc.familyData.largo_min > 0 or fsc.familyData.largo_max > 0 %}
                    {{ trans('largo') }}: {{ fsc.familyData.largo_min }} - {{ fsc.familyData.largo_max }} cm<br>
                    {% endif %}
                    {% if fsc.familyData.ancho_min > 0 or fsc.familyData.ancho_max > 0 %}
                    {{ trans('ancho') }}: {{ fsc.familyData.ancho_min }} - {{ fsc.familyData.ancho_max }} cm
                    {% endif %}
                </p>
                {% endif %}

                <div class="row g-2 mb-3">
                    <div class="col-auto">
                        <label class="form-label" for="largo_cm">{{ trans('largo') }}</label>
                        <input type="number" id="largo_cm" name="largo_cm" class="form-control" step="0.01"
                            min="{{ fsc.familyData and fsc.familyData.largo_min > 0 ? fsc.familyData.largo_min : '0.01' }}"
                            {% if fsc.familyData and fsc.familyData.largo_max > 0 %}max="{{ fsc.familyData.largo_max }}"{% endif %}
                            required oninput="calculateTablerosPrice()">
                    </div>
                    <div class="col-auto">
                        <label class="form-label" for="ancho_cm">{{ trans('ancho') }}</label>
                        <input type="number" id="ancho_cm" name="ancho_cm" class="form-control" step="0.01"
                            min="{{ fsc.familyData and fsc.familyData.ancho_min > 0 ? fsc.familyData.ancho_min : '0.01' }}"
                            {% if fsc.familyData and fsc.familyData.ancho_max > 0 %}max="{{ fsc.familyData.ancho_max }}"{% endif %}
                            required oninput="calculateTablerosPrice()">
                    </div>
                </div>

                <div class="mb-3" id="tableros-calc" style="display:none;">
                    <p class="mb-1"><strong>{{ trans('area') }}:</strong> <span id="tableros-area">0</span> m²</p>
                    <p class="mb-1"><strong>{{ trans('calculated-price') }}:</strong> <span id="tableros-total-price">0,00 €</span></p>
                </div>

                <button type="submit" id="add-to-cart-btn" class="btn btn-primary btn-lg">
                    <i class="fa-solid fa-cart-plus"></i> {{ trans('add-to-presupuesto') }}
                </button>
            </form>
            {% else %}
            <button class="btn btn-secondary btn-lg" disabled>
                <i class="fa-solid fa-ban"></i> {{ trans('out-of-stock') }}
            </button>
            {% endif %}

            {# === NORMAL / MERCANCÍA / TABLONES: standard add to cart === #}
            {% else %}
            {% set showForm = fsc.productVariants is not empty or fsc.product.stock > 0 or fsc.product.nostock %}
            {% if showForm %}
            <form method="post" action="{{ asset('ProductoDetalle') }}?url={{ fsc.product.slug }}">
                <input type="hidden" name="action" value="add-to-cart">
                <input type="hidden" name="product_referencia" id="add-referencia"
                    value="{{ fsc.defaultVariant ? fsc.defaultVariant.referencia : fsc.product.referencia }}">
                <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">

                {% if fsc.familyType != 'artesania' %}
                <div class="input-group mb-3" style="max-width: 200px;">
                    <label class="input-group-text" for="qty">{{ trans('quantity') }}</label>
                    <input type="number" id="qty" name="quantity" value="1" min="1" {% if fsc.product.nostock %}max="999"{% else %}max="{{ currentStock }}"{% endif %} class="form-control">
                </div>
                {% else %}
                <input type="hidden" name="quantity" value="1">
                {% endif %}

                <button type="submit" id="add-to-cart-btn" class="btn btn-primary btn-lg"
                    {% if not fsc.product.nostock and currentStock <= 0 %}disabled{% endif %}>
                    <i class="fa-solid fa-cart-plus"></i> {{ trans('add-to-presupuesto') }}
                </button>
            </form>
            {% else %}
            <button class="btn btn-secondary btn-lg" disabled>
                <i class="fa-solid fa-ban"></i> {{ trans('out-of-stock') }}
            </button>
            {% endif %}
            {% endif %}
        </div>
    </div>

    {# Vertical image gallery with descriptions #}
    {% if fsc.productImages | length > 1 %}
    <div class="row mt-2 mb-4">
        <div class="col-12">
            <h5>{{ trans('product-images') }}</h5>
            <div id="product-gallery" class="d-flex flex-column gap-3">
                {% for img in fsc.productImages %}
                <div class="gallery-item" data-idvariante="{{ img.idvariante ?? '' }}" style="max-width: 400px;">
                    <img src="{{ img.url }}" class="img-thumbnail w-100" alt="{{ img.alt }}"
                         style="object-fit: cover; cursor: pointer;"
                         onclick="scrollCarouselTo({{ loop.index0 }})">
                    {% if img.description is not empty %}
                    <p class="mt-1 mb-0 text-muted small">{{ img.description }}</p>
                    {% endif %}
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    {% endif %}

    {% else %}
    <div class="alert alert-warning">
        <i class="fa-solid fa-exclamation-triangle"></i> {{ trans('product-not-found') }}
    </div>
    <a href="{{ asset('Tableros') }}" class="btn btn-primary">
        <i class="fa-solid fa-arrow-left"></i> {{ trans('tableros') }}
    </a>
    {% endif %}

    {% if fsc.cartItemCount > 0 %}
    <div class="fixed-bottom mb-3 me-3 text-end">
        <a href="{{ asset('Presupuesto') }}" class="btn btn-success btn-lg shadow">
            <i class="fa-solid fa-file-invoice"></i>
            {{ trans('view-presupuesto') }} ({{ fsc.cartItemCount }})
        </a>
    </div>
    {% endif %}
</div>

<script>
var variantData = {{ fsc.productVariants | json_encode | raw }};
var variantImages = {{ fsc.variantImages | json_encode | raw }};
var allImages = {{ fsc.productImages | json_encode | raw }};
var productBaseName = {{ fsc.product.name | json_encode | raw }};
var inStockLabel = {{ trans('in-stock') | json_encode | raw }};
var outOfStockLabel = {{ trans('out-of-stock') | json_encode | raw }};
var soldLabel = {{ trans('sold') | json_encode | raw }};
var familyType = {{ fsc.familyType | json_encode | raw }};

function formatMoney(amount) {
    return amount.toFixed(2).replace('.', ',') + ' \u20ac';
}

function updateCarouselForVariant(idvariante) {
    var inner = document.getElementById('carousel-inner');
    if (!inner) return;

    var items = inner.querySelectorAll('.carousel-item');
    var idvarianteStr = idvariante !== null && idvariante !== undefined ? String(idvariante) : '';
    var hasVariantImages = idvarianteStr !== '' && variantImages[idvariante] && variantImages[idvariante].length > 0;

    var visibleCount = 0;
    items.forEach(function (item) {
        var itemVariante = item.dataset.idvariante;
        var show;
        if (hasVariantImages) {
            show = itemVariante === idvarianteStr;
        } else {
            // No variant-specific images: show all images
            show = true;
        }
        item.style.display = show ? '' : 'none';
        if (show) visibleCount++;
    });

    // Ensure one item is active
    var activeFound = false;
    items.forEach(function (item) {
        if (item.style.display !== 'none') {
            if (!activeFound) {
                item.classList.add('active');
                activeFound = true;
            } else {
                item.classList.remove('active');
            }
        } else {
            item.classList.remove('active');
        }
    });

    // Show/hide prev/next buttons
    var prevBtn = document.getElementById('carousel-prev');
    var nextBtn = document.getElementById('carousel-next');
    if (prevBtn) prevBtn.style.display = visibleCount > 1 ? '' : 'none';
    if (nextBtn) nextBtn.style.display = visibleCount > 1 ? '' : 'none';

    // Update gallery items
    var galleryItems = document.querySelectorAll('.gallery-item');
    galleryItems.forEach(function (gi) {
        var giVariante = gi.dataset.idvariante;
        var show;
        if (hasVariantImages) {
            show = giVariante === idvarianteStr;
        } else {
            show = true;
        }
        gi.style.display = show ? '' : 'none';
    });
}

function updateProductTitle(description) {
    var title = document.getElementById('product-title');
    var breadcrumb = document.getElementById('breadcrumb-product-name');
    var fullName = description ? productBaseName + ' \u2013 ' + description : productBaseName;
    if (title) title.textContent = fullName;
    if (breadcrumb) breadcrumb.textContent = fullName;
}

function updateDimensionsTable(variant) {
    if (familyType !== 'tablones') return;
    var largoEl = document.getElementById('dim-largo');
    var anchoEl = document.getElementById('dim-ancho');
    var espesorEl = document.getElementById('dim-espesor');
    if (largoEl) largoEl.textContent = (variant.largo !== null && variant.largo !== '') ? variant.largo : '';
    if (anchoEl) anchoEl.textContent = (variant.ancho !== null && variant.ancho !== '') ? variant.ancho : '';
    if (espesorEl) espesorEl.textContent = (variant.espesor !== null && variant.espesor !== '') ? variant.espesor : '';
}

function updateVariantFromAttributes() {
    var selected = {};
    document.querySelectorAll('.attr-selector').forEach(function (sel) {
        selected[sel.dataset.codatributo] = parseInt(sel.value, 10);
    });

    var match = null;
    for (var i = 0; i < variantData.length; i++) {
        var v = variantData[i];
        var allMatch = true;
        for (var cod in selected) {
            if (!v.attributes || v.attributes[cod] !== selected[cod]) {
                allMatch = false;
                break;
            }
        }
        if (allMatch) {
            match = v;
            break;
        }
    }

    if (match) {
        var refInput = document.getElementById('add-referencia');
        if (refInput) refInput.value = match.referencia;

        var priceEl = document.getElementById('variant-price');
        if (priceEl) {
            priceEl.textContent = formatMoney(parseFloat(match.price));
            if (familyType === 'tableros') priceEl.innerHTML += ' <small class="text-muted">/m²</small>';
        }

        var inStock = parseFloat(match.stock) > 0;
        var badge = document.getElementById('variant-stock-badge');
        if (badge) {
            if (familyType === 'tableros') {
                // Tableros: stock not controlled, no badge
                badge.className = '';
                badge.textContent = '';
            } else if (familyType === 'artesania' && !inStock) {
                badge.className = 'badge bg-warning text-dark fs-6';
                badge.textContent = soldLabel;
            } else {
                badge.className = inStock ? 'badge bg-success fs-6' : 'badge bg-danger fs-6';
                badge.textContent = inStock ? inStockLabel : outOfStockLabel;
            }
        }

        var addBtn = document.getElementById('add-to-cart-btn');
        if (addBtn) {
            if (familyType === 'tableros') {
                addBtn.disabled = false;
            } else if (familyType === 'artesania' && !inStock) {
                addBtn.disabled = true;
            } else {
                addBtn.disabled = !inStock;
            }
        }

        var qtyInput = document.getElementById('qty');
        if (qtyInput && inStock) qtyInput.max = Math.floor(match.stock);

        updateProductTitle(match.description);
        updateCarouselForVariant(match.idvariante);
        updateDimensionsTable(match);

        // Recalculate Tableros price if applicable
        if (familyType === 'tableros') calculateTablerosPrice();
    }
}

function updateVariant(select) {
    var option = select.options[select.selectedIndex];
    var refInput = document.getElementById('add-referencia');
    if (refInput) refInput.value = option.value;

    var price = parseFloat(option.dataset.price);
    var priceEl = document.getElementById('variant-price');
    if (priceEl) {
        priceEl.textContent = formatMoney(price);
        if (familyType === 'tableros') priceEl.innerHTML += ' <small class="text-muted">/m²</small>';
    }

    var stock = parseFloat(option.dataset.stock);
    var inStock = stock > 0;
    var badge = document.getElementById('variant-stock-badge');
    if (badge) {
        if (familyType === 'tableros') {
            // Tableros: stock not controlled, no badge
            badge.className = '';
            badge.textContent = '';
        } else if (familyType === 'artesania' && !inStock) {
            badge.className = 'badge bg-warning text-dark fs-6';
            badge.textContent = soldLabel;
        } else {
            badge.className = inStock ? 'badge bg-success fs-6' : 'badge bg-danger fs-6';
            badge.textContent = inStock ? inStockLabel : outOfStockLabel;
        }
    }

    var addBtn = document.getElementById('add-to-cart-btn');
    if (addBtn) {
        if (familyType === 'tableros') {
            addBtn.disabled = false;
        } else if (familyType === 'artesania' && !inStock) {
            addBtn.disabled = true;
        } else {
            addBtn.disabled = !inStock;
        }
    }

    var qtyInput = document.getElementById('qty');
    if (qtyInput && inStock) qtyInput.max = Math.floor(stock);

    updateProductTitle(option.dataset.description || '');
    updateCarouselForVariant(option.dataset.idvariante || null);

    // Update Tablones dimensions from data attributes
    if (familyType === 'tablones') {
        var variant = {
            largo: option.dataset.largo !== '' ? option.dataset.largo : null,
            ancho: option.dataset.ancho !== '' ? option.dataset.ancho : null,
            espesor: option.dataset.espesor !== '' ? option.dataset.espesor : null
        };
        updateDimensionsTable(variant);
    }

    // Recalculate Tableros price if applicable
    if (familyType === 'tableros') calculateTablerosPrice();
}

function calculateTablerosPrice() {
    var largoInput = document.getElementById('largo_cm');
    var anchoInput = document.getElementById('ancho_cm');
    var calcDiv = document.getElementById('tableros-calc');
    var areaSpan = document.getElementById('tableros-area');
    var totalSpan = document.getElementById('tableros-total-price');

    if (!largoInput || !anchoInput) return;

    var largo = parseFloat(largoInput.value) || 0;
    var ancho = parseFloat(anchoInput.value) || 0;

    if (largo > 0 && ancho > 0) {
        var areaCm2 = largo * ancho;
        var areaM2 = areaCm2 / 10000;
        // Get current variant price (€/m²)
        var pricePerM2 = 0;
        var refInput = document.getElementById('add-referencia');
        if (refInput) {
            for (var i = 0; i < variantData.length; i++) {
                if (variantData[i].referencia === refInput.value) {
                    pricePerM2 = parseFloat(variantData[i].price);
                    break;
                }
            }
        }
        // Fallback to product price if no variant found
        if (pricePerM2 === 0) {
            var priceEl = document.getElementById('variant-price');
            if (priceEl) {
                var priceText = priceEl.textContent.replace(/[^\d,.-]/g, '').replace(',', '.');
                pricePerM2 = parseFloat(priceText) || 0;
            }
        }
        var totalPrice = pricePerM2 * areaM2;
        if (areaSpan) areaSpan.textContent = areaM2.toFixed(4);
        if (totalSpan) totalSpan.textContent = formatMoney(totalPrice);
        if (calcDiv) calcDiv.style.display = '';
    } else {
        if (calcDiv) calcDiv.style.display = 'none';
    }
}

function scrollCarouselTo(index) {
    var inner = document.getElementById('carousel-inner');
    if (!inner) return;
    var visibleItems = Array.from(inner.querySelectorAll('.carousel-item')).filter(function(el) {
        return el.style.display !== 'none';
    });
    if (index < visibleItems.length) {
        visibleItems.forEach(function(el) { el.classList.remove('active'); });
        visibleItems[index].classList.add('active');
        visibleItems[index].scrollIntoView({behavior: 'smooth', block: 'nearest'});
    }
}

// On page load all images are shown (server-side rendering already initialises
// price, stock, title and referencia correctly for the default variant).
// Images are filtered only when the user explicitly selects a variant.
</script>
{% endblock %}