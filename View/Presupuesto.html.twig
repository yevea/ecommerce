{% extends "Master/MenuTemplate.html.twig" %}

{% block body %}
<div class="container mt-4" id="presupuesto-content">
    <h1 class="mb-4">
        <i class="fa-solid fa-file-invoice"></i> {{ trans('presupuesto') }}
    </h1>

    {% if fsc.orderSuccess %}
    <div class="alert alert-success text-center py-5">
        <i class="fa-solid fa-circle-check fa-3x mb-3 d-block"></i>
        <h3>{{ trans('order-placed-successfully') }}</h3>
        {% if fsc.orderCode is not empty %}
        <p class="lead">{{ trans('order-code') }}: <strong>{{ fsc.orderCode }}</strong></p>
        {% endif %}
        <a href="{{ asset('Productos') }}" class="btn btn-primary mt-3">
            <i class="fa-solid fa-arrow-left"></i> {{ trans('go-to-store') }}
        </a>
    </div>

    {% elseif fsc.cartItems is not empty %}
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>{{ trans('product') }}</th>
                            <th class="text-center">{{ trans('price') }}</th>
                            <th class="text-center" style="width: 150px;">{{ trans('quantity') }}</th>
                            <th class="text-end">{{ trans('subtotal') }}</th>
                            <th class="text-center no-print" style="width: 80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in fsc.cartItems %}
                        <tr>
                            <td>
                                {{ item.product_name }}
                                {% if item.measurement_value is not null and item.measurement_value > 0 %}
                                <br><small class="text-muted">
                                    {{ item.measurement_value | number_format(2, ',', '.') }} {{ item.measurement_unit }}
                                    {% if item.pricing_mode == 'quantity_based' %}
                                    &rarr; {{ item.quantity }} {{ trans('units') }}
                                    {% endif %}
                                </small>
                                {% endif %}
                            </td>
                            <td class="text-center">{{ fsc.formatMoney(item.product_price) }}</td>
                            <td class="text-center">
                                <span class="print-only">
                                    {% if item.measurement_value is not null and item.measurement_value > 0 and item.pricing_mode == 'per_measurement' %}
                                        {{ item.measurement_value | number_format(2, ',', '.') }} {{ item.measurement_unit }}
                                    {% else %}
                                        {{ item.quantity }}
                                    {% endif %}
                                </span>
                                {% if item.measurement_value is not null and item.measurement_value > 0 and item.pricing_mode == 'per_measurement' %}
                                {# Per-measurement items: allow updating the measurement value #}
                                <form method="post" action="{{ asset('Presupuesto') }}" class="d-inline no-print">
                                    <input type="hidden" name="action" value="update-quantity">
                                    <input type="hidden" name="cart_item_id" value="{{ item.id }}">
                                    <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="measurement_value"
                                            value="{{ item.measurement_value }}"
                                            min="{{ item.min_value > 0 ? item.min_value : item.step_value }}"
                                            step="{{ item.step_value }}"
                                            class="form-control text-center" style="max-width:90px;">
                                        <span class="input-group-text">{{ item.measurement_unit }}</span>
                                        <button type="submit" class="btn btn-outline-primary btn-sm">
                                            <i class="fa-solid fa-sync"></i>
                                        </button>
                                    </div>
                                </form>
                                {% else %}
                                <form method="post" action="{{ asset('Presupuesto') }}" class="d-inline no-print">
                                    <input type="hidden" name="action" value="update-quantity">
                                    <input type="hidden" name="cart_item_id" value="{{ item.id }}">
                                    <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">
                                    <div class="input-group input-group-sm">
                                        <input type="number" name="quantity" value="{{ item.quantity }}" min="1" max="999" class="form-control text-center">
                                        <button type="submit" class="btn btn-outline-primary btn-sm">
                                            <i class="fa-solid fa-sync"></i>
                                        </button>
                                    </div>
                                </form>
                                {% endif %}
                            </td>
                            <td class="text-end">{{ fsc.formatMoney(item.subtotal) }}</td>
                            <td class="text-center no-print">
                                <form method="post" action="{{ asset('Presupuesto') }}" class="d-inline">
                                    <input type="hidden" name="action" value="remove-item">
                                    <input type="hidden" name="cart_item_id" value="{{ item.id }}">
                                    <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr class="table-active">
                            <td colspan="3" class="text-end fw-bold">{{ trans('total') }}:</td>
                            <td class="text-end fw-bold">{{ fsc.formatMoney(fsc.cartTotal) }}</td>
                            <td class="no-print"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-4 no-print">
        <div class="card-header">
            <h5 class="mb-0">{{ trans('checkout') }}</h5>
        </div>
        <div class="card-body">
            <form method="post" action="{{ asset('Presupuesto') }}" id="checkout-form">
                <input type="hidden" name="action" value="place-order">
                <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label for="customer_name" class="form-label">{{ trans('customer-name') }} *</label>
                        <input type="text" name="customer_name" id="customer_name" class="form-control" required>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="customer_nif" class="form-label">{{ trans('customer-nif') }}</label>
                        <input type="text" name="customer_nif" id="customer_nif" class="form-control" maxlength="30">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="customer_email" class="form-label">{{ trans('customer-email') }}</label>
                        <input type="email" name="customer_email" id="customer_email" class="form-control">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="customer_phone" class="form-label">{{ trans('customer-phone') }}</label>
                        <input type="tel" name="customer_phone" id="customer_phone" class="form-control" maxlength="30">
                    </div>
                    <div class="col-12 mb-3">
                        <label for="address" class="form-label">{{ trans('address') }}</label>
                        <input type="text" name="address" id="address" class="form-control">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label for="customer_zip" class="form-label">{{ trans('customer-zip') }}</label>
                        <input type="text" name="customer_zip" id="customer_zip" class="form-control" maxlength="10">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label for="customer_city" class="form-label">{{ trans('customer-city') }}</label>
                        <input type="text" name="customer_city" id="customer_city" class="form-control">
                    </div>
                    <div class="col-md-4 mb-3">
                        <label for="customer_province" class="form-label">{{ trans('customer-province') }}</label>
                        <input type="text" name="customer_province" id="customer_province" class="form-control">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label for="customer_country" class="form-label">{{ trans('customer-country') }}</label>
                        <input type="text" name="customer_country" id="customer_country" class="form-control" value="ES" maxlength="10">
                    </div>
                    <div class="col-12 mb-3">
                        <label for="notes" class="form-label">{{ trans('notes') }}</label>
                        <textarea name="notes" id="notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3 mb-4">
        <a href="{{ asset('Productos') }}" class="btn btn-outline-secondary no-print">
            <i class="fa-solid fa-arrow-left"></i> {{ trans('continue-shopping') }}
        </a>
        <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary no-print" onclick="submitPrintPresupuesto()">
                <i class="fa-solid fa-print"></i> {{ trans('print-presupuesto') }}
            </button>
            <button type="submit" form="checkout-form" class="btn btn-success btn-lg no-print">
                <i class="fa-solid fa-check"></i> {{ trans('place-order') }}
            </button>
        </div>
    </div>

    {% else %}
    <div class="alert alert-info">
        <i class="fa-solid fa-info-circle"></i> {{ trans('presupuesto-empty') }}
    </div>
    <a href="{{ asset('Productos') }}" class="btn btn-primary">
        <i class="fa-solid fa-arrow-left"></i> {{ trans('go-to-store') }}
    </a>
    {% endif %}
</div>

<style>
@media print {
    .no-print { display: none !important; }
    .print-only { display: inline !important; }
    #presupuesto-content { margin: 0; padding: 0; }
}
.print-only { display: none; }
</style>
<script>
function submitPrintPresupuesto() {
    const form = document.getElementById('checkout-form');
    const actionInput = form.querySelector('input[name="action"]');
    const original = actionInput.value;
    actionInput.value = 'print-presupuesto';
    form.submit();
    actionInput.value = original;
}
</script>
{% endblock %}
