{#
/**
 * This file is part of ecommerce plugin for FacturaScripts.
 * Copyright (C) 2024 FacturaScripts Community
 *
 * Overrides the core ProductoImagen tab to add an observations field
 * to the image upload form.
 */
#}
{% set firstView = fsc.views | first %}
{% set product = firstView.model %}
{% set currentView = fsc.getCurrentView() %}

<div class="container-fluid">
    {# -- New form -- #}
    <div class="row">
        <div class="col">
            <form id="{{ 'form' ~ currentView.getViewName() ~ '0' }}" action="{{ product.url() }}" method="post"
                  enctype="multipart/form-data" onsubmit="animateSpinner('add')">
                {{ formToken() }}
                <input type="hidden" name="action" value="add-image"/>
                <input type="hidden" name="activetab" value="{{ currentView.getViewName() }}"/>
                <input type="hidden" name="idproducto" value="{{ product.primaryColumnValue() }}">
                <div class="card border-success shadow mb-3">
                    <div class="card-body p-3">
                        <div class="row g-2">
                            <div class="col-sm-2">
                                {{ trans('variant') }}
                                <select name="referencia" class="form-select mb-2">
                                    <option value="">{{ trans('all-variants') }}</option>
                                    <option value="">------</option>
                                    {% for variant in product.getVariants() %}
                                        <option value="{{ variant.referencia }}">{{ variant.referencia }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col">
                                {{ trans('observations') }}
                                <textarea name="observations" class="form-control mb-2"
                                          placeholder="{{ trans('observations') }}"></textarea>
                                <div class="row g-2 mb-2">
                                    <div class="col">
                                        {{ trans('short-description') }}
                                        <textarea name="descripcion_corta" class="form-control" rows="3"
                                                  maxlength="300"
                                                  placeholder="{{ trans('short-description-placeholder') }}"></textarea>
                                    </div>
                                </div>
                                {{ trans('images') }}
                                <input type="file" name="newfiles[]" class="form-control" multiple=""
                                       accept="image/png, image/jpeg, image/gif" required/>
                                <p class="text-muted mb-2">
                                    {{ trans('help-server-accepts-filesize', {'%size%': currentView.model.getMaxFileUpload()}) }}
                                </p>
                            </div>
                            <div class="col-auto">
                                <br/>
                                <button type="submit" class="btn btn-success mb-2">
                                    <i class="fa-solid fa-save fa-fw" aria-hidden="true"></i> {{ trans('add') }}
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
    {# -- Attached files -- #}
    <div class="row row-cols-1 row-cols-md-5" id="images-container">
        {% for counter, image in currentView.cursor %}
            <div class="col mb-4 images-item" data-image-id="{{ image.id }}">
                {% set border = image.referencia ? '' : 'border-primary' %}
                {% set formName = currentView.getViewName() ~ (counter + 1) %}
                {% set fullFileName = image.url('download') | split('/') | last %}
                <div class="card {{ border }} shadow">
                    <img src="{{ asset(image.url('download')) }}" class="card-img-top"
                         alt="{{ image.descripcion_corta is defined and image.descripcion_corta is not empty ? image.descripcion_corta : image.referencia }}" loading="lazy">
                    <form id="{{ 'form' ~ formName }}" action="{{ product.url() }}" method="post"
                          onsubmit="animateSpinner('add')">
                        {{ formToken() }}
                        <input type="hidden" name="action" value=""/>
                        <input type="hidden" name="activetab" value="{{ currentView.getViewName() }}"/>
                        <input type="hidden" name="idproducto" value="{{ image.idproducto }}"/>
                        <input type="hidden" name="idimage" value="{{ image.id }}"/>
                        <div class="card-body p-2">
                            <div class="mb-1">
                                <select name="referencia" class="form-select form-select-sm">
                                    <option value="">{{ trans('all-variants') }}</option>
                                    {% for variant in product.getVariants() %}
                                        <option value="{{ variant.referencia }}" {% if variant.referencia == image.referencia %}selected{% endif %}>{{ variant.referencia }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="mb-1">
                                <textarea name="observaciones" class="form-control form-control-sm" rows="2"
                                          placeholder="{{ trans('observations') }}">{{ image.observaciones }}</textarea>
                            </div>
                            <div class="mb-1">
                                <input type="text" name="descripcion_corta" class="form-control form-control-sm"
                                       maxlength="300" placeholder="{{ product.descripcion }}"
                                       value="{{ image.descripcion_corta is defined and image.descripcion_corta is not empty ? image.descripcion_corta : '' }}">
                            </div>
                            <div class="mb-1">
                                {% set fileExt = fullFileName | split('.') | last %}
                                {% set fileBase = fullFileName | slice(0, -(fileExt | length + 1)) %}
                                <div class="input-group input-group-sm">
                                    <input type="text" name="nombre_archivo" class="form-control"
                                           maxlength="90" placeholder="{{ trans('rename-file') }}"
                                           value="{{ fileBase }}">
                                    <span class="input-group-text">.{{ fileExt }}</span>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="row align-items-center">
                                <div class="col">
                                    <button type="button" class="btn btn-sm btn-primary"
                                            onclick="submitEditImage('{{ formName }}');">
                                        <i class="fa-solid fa-save fa-fw" aria-hidden="true"></i>
                                    </button>
                                </div>
                                <div class="col-auto">
                                    {{ _self.buttonDelete(formName) }}
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        {% endfor %}
    </div>
    {% if currentView.count > 1 %}
        <div class="alert alert-info">{{ trans('you-can-sort-images') }}</div>
    {% endif %}
</div>
<script>
function submitEditImage(formName) {
    var form = document.getElementById('form' + formName);
    form.querySelector('[name="action"]').value = 'edit-image';
    form.submit();
}
</script>

{% macro buttonDelete(formName) %}
    {% set label = trans('delete-file') %}
    {% set text = trans('are-you-sure') %}
    {% set cancel = trans('cancel') %}
    {% set confirm = trans('confirm') %}
    <button type="button" class="btn btn-sm btn-outline-danger p-1"
            onclick="confirmAction('{{ formName }}','delete-image','{{ label }}','{{ text }}','{{ cancel }}','{{ confirm }}');">
        <i class="fa-solid fa-trash-alt fa-fw" aria-hidden="true"></i>
    </button>
{% endmacro %}
