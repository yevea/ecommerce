{% extends "Master/MenuTemplate.html.twig" %}

{% block navbar %}{% endblock %}

{% block body %}
{% include 'Header.html.twig' %}
{# Schema.org structured data for AI agents and search engines #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Store",
    "name": "{{ trans('sawmill') }}",
    "description": "{{ trans('sawmill-desc') }}",
    "url": "{{ asset('StoreFront') }}",
    "areaServed": [
        {"@type": "Country", "name": "Spain"},
        {"@type": "Country", "name": "France"},
        {"@type": "Country", "name": "Germany"},
        {"@type": "Place", "name": "European Union"}
    ],
    "availableLanguage": ["es", "en", "fr", "de"],
    "currenciesAccepted": "EUR",
    "paymentAccepted": "Credit Card, Stripe",
    "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "{{ trans('products') }}",
        "itemListElement": [
            {% for product in fsc.products %}
            {
                "@type": "Product",
                "name": "{{ product.name | e('js') }}",
                "description": "{{ product.description | e('js') }}",
                "sku": "{{ product.referencia }}",
                "url": "{{ asset('ProductoDetalle') }}?url={{ product.slug }}",
                {% if product.image %}"image": "{{ product.image }}",{% endif %}
                "material": "{{ trans('olive-wood') }}",
                "offers": {
                    "@type": "Offer",
                    "price": "{{ product.price }}",
                    "priceCurrency": "EUR",
                    "availability": "{% if product.isSold is defined and product.isSold %}https://schema.org/SoldOut{% elseif product.nostock is defined and product.nostock %}https://schema.org/InStock{% elseif product.stock > 0 %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
                    "areaServed": {
                        "@type": "Place",
                        "name": "European Union"
                    }
                }
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ]
    }
}
</script>

<div class="container mt-4" itemscope itemtype="https://schema.org/Store">
    <meta itemprop="name" content="{{ trans('sawmill') }}">
    <meta itemprop="description" content="{{ trans('sawmill-desc') }}">

    <h1 class="mb-4">
        <i class="fa-solid fa-store"></i> {{ trans('storefront') }}
    </h1>

    {% if fsc.categories is not empty %}
    <nav class="row mb-3" aria-label="{{ trans('categories') }}">
        <div class="col-12">
            <div class="btn-group flex-wrap" role="group">
                <a href="{{ asset('StoreFront') }}" class="btn btn-outline-primary {% if fsc.selectedCategory is null %}active{% endif %}">
                    {{ trans('all') }}
                </a>
                {% for cat in fsc.categories %}
                <a href="{{ asset('StoreFront') }}?category={{ cat.codfamilia }}" class="btn btn-outline-primary {% if fsc.selectedCategory == cat.codfamilia %}active{% endif %}">
                    {{ cat.descripcion }}
                </a>
                {% endfor %}
            </div>
        </div>
    </nav>
    {% endif %}

    <div class="row" itemprop="hasOfferCatalog" itemscope itemtype="https://schema.org/OfferCatalog">
        {% for product in fsc.products %}
        <div class="col-6 col-md-4 col-lg-3 mb-4">
            <article class="card h-100 shadow-sm" itemscope itemtype="https://schema.org/Product">
                <meta itemprop="sku" content="{{ product.referencia }}">
                <meta itemprop="material" content="{{ trans('olive-wood') }}">
                <a href="{{ asset('ProductoDetalle') }}?url={{ product.slug }}" class="text-decoration-none text-dark" itemprop="url">
                    {% if product.image %}
                    <img src="{{ product.image }}" class="card-img-top" alt="{{ product.name }}" itemprop="image" style="height: 200px; object-fit: cover;">
                    {% else %}
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                        <i class="fa-solid fa-image fa-3x text-muted"></i>
                    </div>
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <h2 class="card-title h5" itemprop="name">{{ product.name }}</h2>
                        <p class="card-text text-muted small flex-grow-1" itemprop="description">
                            {{ product.description | slice(0, 100) }}{% if product.description | length > 100 %}...{% endif %}
                        </p>
                        <div class="d-flex justify-content-between align-items-center mt-2" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                            <meta itemprop="priceCurrency" content="EUR">
                            <span class="mb-0" itemprop="price" content="{{ product.price }}">{{ fsc.formatMoney(product.price) }}</span>
                            {% if product.stock > 0 %}
                            <link itemprop="availability" href="https://schema.org/InStock">
                            <span class="badge bg-success">{{ trans('in-stock') }}</span>
                            {% elseif product.nostock is defined and product.nostock %}
                            <link itemprop="availability" href="https://schema.org/InStock">
                            {% else %}
                            <link itemprop="availability" href="https://schema.org/OutOfStock">
                            <span class="badge bg-danger">{{ trans('out-of-stock') }}</span>
                            {% endif %}
                        </div>
                    </div>
                </a>
                <div class="card-footer bg-white">
                    {% if product.stock > 0 or (product.nostock is defined and product.nostock) %}
                    <form method="post" action="{{ asset('StoreFront') }}">
                        <input type="hidden" name="action" value="add-to-cart">
                        <input type="hidden" name="product_referencia" value="{{ product.referencia }}">
                        <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fa-solid fa-cart-plus"></i> {{ trans('add-to-presupuesto') }}
                        </button>
                    </form>
                    <form method="post" action="{{ asset('StoreFront') }}">
                        <input type="hidden" name="action" value="stripe-checkout">
                        <input type="hidden" name="product_referencia" value="{{ product.referencia }}">
                        <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">
                        <button type="submit" class="btn btn-dark w-100 mt-2">
                            <i class="fa-brands fa-stripe"></i> {{ trans('buy-with-stripe') }}
                        </button>
                    </form>
                    {% else %}
                    <button class="btn btn-secondary w-100" disabled>
                        <i class="fa-solid fa-ban"></i> {{ trans('out-of-stock') }}
                    </button>
                    {% endif %}
                </div>
            </article>
        </div>
        {% else %}
        <div class="col-12">
            <div class="alert alert-info">
                <i class="fa-solid fa-info-circle"></i> {{ trans('no-products-available') }}
            </div>
        </div>
        {% endfor %}
    </div>

    {% if fsc.cartItemCount > 0 %}
    <div class="fixed-bottom mb-3 me-3 text-end">
        <a href="{{ asset('Presupuesto') }}" class="btn btn-success btn-lg shadow">
            <i class="fa-solid fa-file-invoice"></i>
            {{ trans('view-presupuesto') }} ({{ fsc.cartItemCount }})
        </a>
    </div>
    {% endif %}
</div>
{% endblock %}
