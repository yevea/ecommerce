root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.php]
indent_style = space
indent_size = 4

[*.xml]
indent_style = space
indent_size = 4

[*.json]
indent_style = space
indent_size = 4

[*.{html.twig,twig}]
indent_style = space
indent_size = 4

[*.{js,css}]
indent_style = space
indent_size = 4

[*.ini]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false
