<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="settings" numcolumns="12">
            <column name="reference" numcolumns="6">
                <widget type="text" fieldname="product_referencia" required="true" />
            </column>
            <column name="measurement-enabled" numcolumns="3">
                <widget type="checkbox" fieldname="measurement_enabled" />
            </column>
            <column name="measurement-type" numcolumns="3">
                <widget type="select" translate="true" fieldname="measurement_type">
                    <values title="length">length</values>
                    <values title="area">area</values>
                    <values title="volume">volume</values>
                    <values title="weight">weight</values>
                    <values title="custom">custom</values>
                </widget>
            </column>
            <column name="pricing-mode" numcolumns="6">
                <widget type="select" translate="true" fieldname="pricing_mode">
                    <values title="per-measurement">per_measurement</values>
                    <values title="quantity-based">quantity_based</values>
                </widget>
            </column>
            <column name="unit-value" numcolumns="6">
                <widget type="number" fieldname="unit_value" decimal="4" />
            </column>
            <column name="measurement-unit" numcolumns="4">
                <widget type="text" fieldname="measurement_unit" />
            </column>
            <column name="min-measurement" numcolumns="4">
                <widget type="number" fieldname="min_value" decimal="4" />
            </column>
            <column name="max-measurement" numcolumns="4">
                <widget type="number" fieldname="max_value" decimal="4" />
            </column>
            <column name="step-measurement" numcolumns="4">
                <widget type="number" fieldname="step_value" decimal="4" />
            </column>
            <column name="custom-label" numcolumns="8">
                <widget type="text" fieldname="custom_label" />
            </column>
        </group>
    </columns>
</view>
